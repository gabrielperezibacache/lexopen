generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("abogado") // admin | abogado | asistente | cliente
  password  String   @default("lexopen")
  avatarColor String @default("#1f6f78")
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  causasAsignadas Causa[]          @relation("AbogadoResponsable")
  documentos      Documento[]
  actividades     Activity[]
  plazos          Plazo[]
  siteMemberships SiteMember[]
  tasksAssigned   Task[]           @relation("TaskAssignee")
  tasksCreated    Task[]           @relation("TaskCreator")
  comments        Comment[]
  messagesSent    Message[]        @relation("MessageSender")
  messagesRecv    Message[]        @relation("MessageReceiver")
  notifications   Notification[]
  qaPosts         QaPost[]
  wikiPages       WikiPage[]
  workflowActions WorkflowInstance[] @relation("WorkflowActor")
  groupMembers    GroupMember[]
  fileVersions    FileVersion[]
  timeEntries     TimeEntry[]
  expenses        Expense[]        @relation("ExpenseAuthor")
  invoicesCreated Invoice[]        @relation("InvoiceAuthor")
  feeArrangements FeeArrangement[] @relation("FeeOwner")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  members     GroupMember[]
  siteAccess  SiteGroup[]
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

/// HighQ Site / Workspace / Data Room
model Site {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  tipo        String   @default("matter") // matter | vdr | client_portal | project | knowledge
  status      String   @default("active") // active | archived
  color       String   @default("#1f6f78")
  isClientVisible Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  causaId String? @unique
  causa   Causa?  @relation(fields: [causaId], references: [id])

  members     SiteMember[]
  groups      SiteGroup[]
  folders     Folder[]
  files       SiteFile[]
  wikiPages   WikiPage[]
  tasks       Task[]
  isheets     ISheet[]
  qaThreads   QaThread[]
  workflows   Workflow[]
  activities  Activity[]
  blogPosts   BlogPost[]
}

model SiteMember {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  role      String   @default("contributor") // admin | contributor | viewer | client
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
}

model SiteGroup {
  id      String @id @default(cuid())
  siteId  String
  groupId String
  role    String @default("viewer")
  site    Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([siteId, groupId])
}

model Cliente {
  id          String   @id @default(cuid())
  razonSocial String
  rut         String?
  email       String?
  telefono    String?
  tipo        String   @default("persona")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  causas          Causa[]
  sites           Site[]
  feeArrangements FeeArrangement[]
  timeEntries     TimeEntry[]
  expenses        Expense[]
  invoices        Invoice[]
  payments        Payment[]
  ledgerEntries   LedgerEntry[]
}

model Causa {
  id            String    @id @default(cuid())
  titulo        String
  rit           String?
  ruc           String?
  tribunal      String
  materia       String
  procedimiento String?
  estado        String    @default("activa")
  etapa         String    @default("ingreso")
  caratula      String?
  resumen       String?
  fechaIngreso  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  abogadoId String?
  abogado   User? @relation("AbogadoResponsable", fields: [abogadoId], references: [id])

  partes          Parte[]
  documentos      Documento[]
  plazos          Plazo[]
  actividades     Activity[]
  notas           Nota[]
  site            Site?
  feeArrangements FeeArrangement[]
  timeEntries     TimeEntry[]
  expenses        Expense[]
  invoices        Invoice[]
  ledgerEntries   LedgerEntry[]
}

model Parte {
  id        String  @id @default(cuid())
  nombre    String
  rut       String?
  rol       String
  domicilio String?
  causaId   String
  causa     Causa   @relation(fields: [causaId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  siteId    String
  parentId  String?
  createdAt DateTime @default(now())

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[]  @relation("FolderTree")
  files    SiteFile[]
}

model SiteFile {
  id          String   @id @default(cuid())
  name        String
  mimeType    String   @default("text/plain")
  sizeBytes   Int      @default(0)
  contenido   String?
  storagePath String?
  version     Int      @default(1)
  checkedOut  Boolean  @default(false)
  tags        String   @default("")
  metadataJson String  @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteId   String
  folderId String?
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  folder   Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  versions FileVersion[]
  comments Comment[]
}

model FileVersion {
  id        String   @id @default(cuid())
  fileId    String
  version   Int
  contenido String?
  note      String?
  createdAt DateTime @default(now())
  authorId  String?
  file      SiteFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])
}

model Documento {
  id            String   @id @default(cuid())
  nombre        String
  tipo          String   @default("otro")
  mimeType      String?
  contenido     String?
  ruta          String?
  version       Int      @default(1)
  obsidianPath  String?
  googleDriveId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  causaId String?
  causa   Causa? @relation(fields: [causaId], references: [id], onDelete: SetNull)
  autorId String?
  autor   User?  @relation(fields: [autorId], references: [id])
}

model Plazo {
  id            String   @id @default(cuid())
  titulo        String
  descripcion   String?
  fechaLimite   DateTime
  tipo          String   @default("procesal")
  estado        String   @default("pendiente")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  causaId       String?
  causa         Causa? @relation(fields: [causaId], references: [id], onDelete: Cascade)
  responsableId String?
  responsable   User?  @relation(fields: [responsableId], references: [id])
}

model Nota {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  tags      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  causaId   String?
  causa     Causa?   @relation(fields: [causaId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  tipo      String
  mensaje   String
  createdAt DateTime @default(now())

  causaId String?
  causa   Causa? @relation(fields: [causaId], references: [id], onDelete: Cascade)
  siteId  String?
  site    Site?  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId  String?
  user    User?  @relation(fields: [userId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // todo | in_progress | blocked | done
  priority    String    @default("medium") // low | medium | high | urgent
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  siteId     String?
  site       Site? @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String?
  creator    User? @relation("TaskCreator", fields: [creatorId], references: [id])

  comments Comment[]
}

model WikiPage {
  id        String   @id @default(cuid())
  title     String
  slug      String
  content   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId   String
  site     Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId String?
  author   User? @relation(fields: [authorId], references: [id])

  @@unique([siteId, slug])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

/// HighQ iSheets — structured collaborative tables
model ISheet {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteId  String
  site    Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  columns ISheetColumn[]
  rows    ISheetRow[]
}

model ISheetColumn {
  id       String @id @default(cuid())
  sheetId  String
  name     String
  key      String
  type     String @default("text") // text | number | date | choice | user | checkbox
  options  String @default("") // comma-separated for choice
  position Int    @default(0)
  sheet    ISheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, key])
}

model ISheetRow {
  id        String   @id @default(cuid())
  sheetId   String
  dataJson  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sheet     ISheet   @relation(fields: [sheetId], references: [id], onDelete: Cascade)
}

model QaThread {
  id        String   @id @default(cuid())
  subject   String
  status    String   @default("open") // open | answered | closed
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts  QaPost[]
}

model QaPost {
  id        String   @id @default(cuid())
  body      String
  isAnswer  Boolean  @default(false)
  createdAt DateTime @default(now())

  threadId String
  thread   QaThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?    @relation(fields: [authorId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  authorId String?
  author   User?     @relation(fields: [authorId], references: [id])
  fileId   String?
  file     SiteFile? @relation(fields: [fileId], references: [id], onDelete: Cascade)
  taskId   String?
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  subject    String?
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  senderId   String
  receiverId String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  read      Boolean  @default(false)
  href      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerType String   @default("manual") // manual | file_upload | task_done | isheet_row
  stepsJson   String   @default("[]") // [{name, role}]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  siteId    String
  site      Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  instances WorkflowInstance[]
}

model WorkflowInstance {
  id          String   @id @default(cuid())
  workflowId  String
  status      String   @default("pending") // pending | approved | rejected | running
  currentStep Int      @default(0)
  payloadJson String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actorId  String?
  actor    User?     @relation("WorkflowActor", fields: [actorId], references: [id])
  workflow Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Jurisprudencia {
  id          String    @id @default(cuid())
  rol         String
  tribunal    String
  sala        String?
  fecha       DateTime?
  materia     String?
  caratula    String?
  descripcion String?
  doctrina    String?
  texto       String?
  url         String?
  fuente      String    @default("LexOpen")
  tags        String    @default("")
  createdAt   DateTime  @default(now())
}

model IntegrationConfig {
  id         String   @id @default(cuid())
  provider   String   @unique
  enabled    Boolean  @default(false)
  configJson String   @default("{}")
  updatedAt  DateTime @updatedAt
}

/// Condición de honorarios del estudio (por causa o cliente)
model FeeArrangement {
  id              String    @id @default(cuid())
  name            String
  tipo            String    @default("hourly") // hourly | flat | retainer | cuota_litis | mixed
  currency        String    @default("CLP") // CLP | UF
  rateHourlyClp   Int? // tarifa horaria en CLP
  rateHourlyUf    Float?
  flatFeeClp      Int?
  retainerClp     Int?
  cuotaLitisPct   Float? // % del resultado
  billingCapClp   Int?
  notes           String?
  active          Boolean   @default(true)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  causaId   String?
  causa     Causa?   @relation(fields: [causaId], references: [id], onDelete: Cascade)
  ownerId   String?
  owner     User?    @relation("FeeOwner", fields: [ownerId], references: [id])
}

model TimeEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  hours       Float
  description String
  billable    Boolean  @default(true)
  billed      Boolean  @default(false)
  rateClp     Int? // override; si null usa fee arrangement / default
  amountClp   Int // hours * rate (calculado al guardar)
  activityCode String  @default("general") // research | hearing | drafting | meeting | travel | general
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  causaId   String?
  causa     Causa?   @relation(fields: [causaId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  description String
  category    String   @default("otro") // notario | receptor | perito | costas | traslado | certificado | otro
  amountClp   Int
  billable    Boolean  @default(true)
  billed      Boolean  @default(false)
  reimbursable Boolean @default(true) // gasto por cuenta del cliente
  vendor      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId  String?
  author    User?    @relation("ExpenseAuthor", fields: [authorId], references: [id])
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  causaId   String?
  causa     Causa?   @relation(fields: [causaId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model Invoice {
  id            String    @id @default(cuid())
  number        String    @unique
  tipoDocumento String    @default("boleta_honorarios") // factura_afecta | boleta_honorarios | nota_credito | factura_exenta
  status        String    @default("borrador") // borrador | emitida | parcialmente_pagada | pagada | vencida | anulada
  currency      String    @default("CLP")
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  subtotalClp   Int       @default(0)
  ivaClp        Int       @default(0) // 19% si factura afecta
  retencionClp  Int       @default(0) // retención boleta honorarios
  totalClp      Int       @default(0)
  paidClp       Int       @default(0)
  notes         String?
  glosa         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])
  causaId   String?
  causa     Causa?  @relation(fields: [causaId], references: [id], onDelete: SetNull)
  authorId  String?
  author    User?   @relation("InvoiceAuthor", fields: [authorId], references: [id])

  lines       InvoiceLine[]
  payments    Payment[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  ledger      LedgerEntry[]
}

model InvoiceLine {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitAmountClp Int
  amountClp   Int
  tipo        String @default("honorario") // honorario | gasto | anticipo | otro
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  amountClp   Int
  method      String   @default("transferencia") // transferencia | cheque | efectivo | tarjeta | retencion
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  ledger    LedgerEntry[]
}

/// Cuenta corriente / provisión de fondos del cliente
model LedgerEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  tipo        String // provision | cargo_honorario | cargo_gasto | pago | ajuste | reembolso
  description String
  debitClp    Int      @default(0) // cargo al cliente
  creditClp   Int      @default(0) // abono / provisión / pago
  balanceClp  Int      @default(0) // saldo tras el movimiento (crédito neto)
  createdAt   DateTime @default(now())

  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  causaId   String?
  causa     Causa?   @relation(fields: [causaId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}
